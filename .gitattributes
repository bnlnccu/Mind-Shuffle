# Unity .gitattributes - ensure consistent line endings across platforms

# Auto detect text files and normalize line endings
* text=auto

# Unity serialized files (YAML) - always LF
*.unity text eol=lf merge=unityyamlmerge
*.prefab text eol=lf merge=unityyamlmerge
*.asset text eol=lf
*.meta text eol=lf
*.mat text eol=lf
*.anim text eol=lf
*.controller text eol=lf

# Scripts
*.cs text eol=lf

# Config
*.json text eol=lf
*.xml text eol=lf
*.txt text eol=lf

# Binary - no text conversion
*.png binary
*.jpg binary
*.jpeg binary
*.psd binary
*.tga binary
*.tif binary
*.wav binary
*.mp3 binary
*.ogg binary
*.fbx binary
*.obj binary
*.dll binary
*.exe binary
*.unitypackage binary
